from cryptography.fernet import Fernet
import os

KEY_FILE = "secret.key"

# Generate and save a key
def generate_key():
    key = Fernet.generate_key()
    with open(KEY_FILE, "wb") as f:
        f.write(key)
    print("[+] Key generated and saved to secret.key")

# Load the key
def load_key():
    if not os.path.exists(KEY_FILE):
        raise FileNotFoundError("[-] Key file not found. Generate one first.")
    return open(KEY_FILE, "rb").read()

# Encrypt a file
def encrypt_file(filename, key):
    fernet = Fernet(key)
    with open(filename, "rb") as f:
        data = f.read()
    encrypted = fernet.encrypt(data)
    with open(filename + ".encrypted", "wb") as f:
        f.write(encrypted)
    print(f"[+] File encrypted: {filename}.encrypted")

# Decrypt a file
def decrypt_file(filename, key):
    fernet = Fernet(key)
    with open(filename, "rb") as f:
        encrypted_data = f.read()
    decrypted = fernet.decrypt(encrypted_data)
    original_name = filename.replace(".encrypted", ".decrypted")
    with open(original_name, "wb") as f:
        f.write(decrypted)
    print(f"[+] File decrypted: {original_name}")

# Main program
if __name__ == "__main__":
    print("=== File Encryption Tool App ===")
    if not os.path.exists(KEY_FILE):
        generate_key()

    key = load_key()

    choice = input("Do you want to (E)ncrypt or (D)ecrypt a file? ").strip().lower()
    filename = input("Enter the file name: ").strip()

    if choice == "e":
        encrypt_file(filename, key)
    elif choice == "d":
        decrypt_file(filename, key)
    else:
        print("[-] Invalid choice.")
